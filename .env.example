# ============ DATABASE ============
DATABASE_URL="postgresql://autocode:autocode@localhost:5432/autocode?schema=public"

# ============ REDIS ============
REDIS_URL="redis://localhost:6379"

# ============ API SERVER ============
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET="change-me-in-production"
CORS_ORIGINS="http://localhost:5173"

# ============ LLM ============
# Supported: gemini, openai, anthropic
LLM_PROVIDER="gemini"
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_MODEL="gemini-2.0-flash"
LLM_MAX_TOKENS=8192

# ============ GITHUB ============
GITHUB_TOKEN=""
GITHUB_WEBHOOK_SECRET=""

# ============ WORKER ============
WORKER_CONCURRENCY=2
WORKER_TIMEOUT_MS=600000
WORKER_MAX_RETRIES=3
WORKER_WORKSPACE_DIR="/tmp/autocode-workspaces"

# ============ SECURITY ============
ENCRYPTION_KEY="change-me-32-chars-minimum-key!!"
